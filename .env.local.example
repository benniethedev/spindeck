# PressBase Configuration
NEXT_PUBLIC_PRESSBASE_URL=https://your-pressbase-url/wp-json/app/v1
PRESSBASE_SERVICE_KEY=pb_sk_your_service_key_here

# Stripe Configuration
# Get these from your Stripe dashboard: https://dashboard.stripe.com/apikeys
#
# ⚠️ IMPORTANT: Use TEST keys for development, LIVE keys for production
# - Test keys start with: sk_test_ / pk_test_
# - Live keys start with: sk_live_ / pk_live_
#
# For DEVELOPMENT (test mode):
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
#
# For PRODUCTION (live mode) - use these in Vercel/production env:
# STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key_here
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_publishable_key_here
#
# Webhook secret (create separate webhooks for test/live in Stripe Dashboard → Webhooks)
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here

# Email Configuration (Resend)
# Get API key from Resend dashboard
RESEND_API_KEY=re_your_resend_api_key_here

# AWS S3 Configuration (Optional - for file storage)
# Only needed if you plan to use AWS S3 for audio/image uploads
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here
AWS_REGION=us-east-1
AWS_S3_BUCKET_NAME=your_s3_bucket_name_here

# NextAuth Configuration (if using custom auth)
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000

# Application Environment
NODE_ENV=development

# Optional: Crisp Chat Support (if using customer support chat)
NEXT_PUBLIC_CRISP_WEBSITE_ID=your_crisp_website_id_here

# Optional: Analytics (Google Analytics, PostHog, etc.)
NEXT_PUBLIC_GA_TRACKING_ID=your_google_analytics_id_here
